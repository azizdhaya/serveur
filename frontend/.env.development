# Port API (49152–65535 : plage dynamique, hors ports « réservés » courants).
VITE_API_PORT=8787
# 127.0.0.1 évite souvent les soucis IPv6 (::1) avec « localhost » sous Windows.
VITE_API_BASE_URL=http://127.0.0.1:8787/api

# Connexion automatique (plus d’écran login) — optionnel, sinon valeurs par défaut = compte seed.
# VITE_DEV_AUTO_LOGIN_EMAIL=admin@photovoltaique.tn
# VITE_DEV_AUTO_LOGIN_PASSWORD=Admin@2024!
