{
  "name": "photovoltaique-dashboard",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-project.mjs",
    "dev": "node scripts/run-dev.mjs",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "install:deps": "powershell -ExecutionPolicy Bypass -File ./install-deps.ps1",
    "db:setup": "npm run prisma:generate --prefix backend && npm run db:push --prefix backend && npm run prisma:seed --prefix backend",
    "prisma:migrate": "npm run prisma:migrate --prefix backend",
    "prisma:seed": "npm run prisma:seed --prefix backend",
    "import:excel": "npm run import:excel --prefix backend",
    "db:push": "npm run db:push --prefix backend",
    "start": "powershell -ExecutionPolicy Bypass -File ./start-dev.ps1"
  }
}
