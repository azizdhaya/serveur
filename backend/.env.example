# MongoDB (nouveau moteur principal). Prisma exige un replica set : voir scripts/enable-mongo-replicaset.ps1
# Après rs.initiate (nom rs0), vous pouvez ajouter &replicaSet=rs0 si la connexion échoue.
DATABASE_URL="mongodb://127.0.0.1:27017/photovoltaique_dashboard?serverSelectionTimeoutMS=5000&connectTimeoutMS=5000"
# Backup SQLite éventuel pendant la transition
SQLITE_DATABASE_URL="file:./prisma/dev.db"

# Option production / serveur : PostgreSQL (nécessite une instance Postgres)
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/photovoltaique_db"
JWT_ACCESS_SECRET="access_secret_key_change_in_production"
JWT_REFRESH_SECRET="refresh_secret_key_change_in_production"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"
PORT=8787
NODE_ENV=development
# En dev (NODE_ENV≠production), l’API assure le compte admin seed au démarrage. Pour désactiver : SKIP_DEV_ADMIN_BOOTSTRAP=1
FRONTEND_URL="http://localhost:5173"
# Timeouts serveur HTTP (ms) pour stabilité long-running.
# SERVER_REQUEST_TIMEOUT_MS=60000
# SERVER_HEADERS_TIMEOUT_MS=65000
# SERVER_KEEP_ALIVE_TIMEOUT_MS=61000
# SERVER_SHUTDOWN_TIMEOUT_MS=10000
