{
  "name": "photovoltaique-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:generate:mongo": "prisma generate --schema prisma/schema.mongodb.prisma",
    "prisma:regen": "powershell -ExecutionPolicy Bypass -File ./scripts/regenerate-prisma.ps1",
    "prisma:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "import:excel": "tsx scripts/import-excel-cli.ts",
    "migrate:sqlite-to-mongo": "npm run prisma:generate:mongo && tsx scripts/migrate-sqlite-to-mongo.ts",
    "mongo:init-rs": "tsx scripts/init-replica-set.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "photovoltaique-dashboard": "file:..",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "mongodb": "^6.12.0",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
